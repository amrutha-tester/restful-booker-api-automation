            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "",
                  "pm.test(\"Booking details are correct\", function () {",
                  "    pm.expect(jsonData.firstname).to.eql(\"Ariana\");",
                  "    pm.expect(jsonData.lastname).to.eql(\"Grande\");",
                  "    pm.expect(jsonData.totalprice).to.eql(200);",
                  "    pm.expect(jsonData.depositpaid).to.eql(true);",
                  "    pm.expect(jsonData.bookingdates.checkin).to.eql(\"2018-01-01\");",
                  "    pm.expect(jsonData.bookingdates.checkout).to.eql(\"2019-01-01\");",
                  "    pm.expect(jsonData.additionalneeds).to.eql(\"Breakfast\");",
                  "});",
                  "pm.test(\"Content-Type header is present and correct\", function () {",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json; charset=utf-8\");",
                  "});",
                  "",
                  "pm.test(\"Get Booking details response schema is valid\", function () {",
                  "    var schema = {",
                  "        \"type\": \"object\",",
                  "        \"required\": [\"firstname\", \"lastname\", \"totalprice\", \"depositpaid\", \"bookingdates\"],",
                  "        \"properties\": {",
                  "            \"firstname\": {",
                  "                \"type\": \"string\"",
