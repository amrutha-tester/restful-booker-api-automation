                  "            },",
                  "            \"depositpaid\": {",
                  "                \"type\": \"boolean\"",
                  "            },",
                  "            \"bookingdates\": {",
                  "                \"type\": \"object\",",
                  "                \"required\": [\"checkin\", \"checkout\"],",
                  "                \"properties\": {",
                  "                    \"checkin\": {",
                  "                        \"type\": \"string\"",
                  "                    },",
                  "                    \"checkout\": {",
                  "                        \"type\": \"string\"",
                  "                    }",
                  "                },",
                  "                \"additionalProperties\": false",
                  "            },",
                  "            \"additionalneeds\": {",
                  "                \"type\": \"string\"",
                  "            }",
                  "        },",
                  "        \"additionalProperties\": false",
                  "    };",
